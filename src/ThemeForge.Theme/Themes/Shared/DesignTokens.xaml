<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Spacing tokens are Thickness values for direct Margin / Padding use. -->
    <Thickness x:Key="SpacingNone">0</Thickness>
    <Thickness x:Key="SpacingXxs">2</Thickness>
    <Thickness x:Key="SpacingXs">4</Thickness>
    <Thickness x:Key="SpacingSm">6</Thickness>
    <Thickness x:Key="SpacingMd">8</Thickness>
    <Thickness x:Key="SpacingLg">12</Thickness>
    <Thickness x:Key="SpacingXl">16</Thickness>
    <Thickness x:Key="SpacingXxl">24</Thickness>
    <Thickness x:Key="SpacingXxxl">32</Thickness>

    <CornerRadius x:Key="RadiusNone">0</CornerRadius>
    <CornerRadius x:Key="RadiusXs">2</CornerRadius>
    <CornerRadius x:Key="RadiusSm">3</CornerRadius>
    <CornerRadius x:Key="RadiusMd">4</CornerRadius>
    <CornerRadius x:Key="RadiusLg">6</CornerRadius>
    <CornerRadius x:Key="RadiusXl">10</CornerRadius>
    <CornerRadius x:Key="RadiusFull">999</CornerRadius>

    <sys:Double x:Key="FontSizeXs">11</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeMd">14</sys:Double>
    <sys:Double x:Key="FontSizeLg">18</sys:Double>
    <sys:Double x:Key="FontSizeXl">22</sys:Double>
</ResourceDictionary>
