<Window
    x:Class="ThemeForge.Studio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dft="clr-namespace:ThemeForge.Controls.Theming;assembly=ThemeForge.Controls"
    Title="ThemeForge Studio"
    Width="1100"
    Height="720"
    MinWidth="800"
    MinHeight="500"
    SizeToContent="Manual"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource SurfaceBrush}"
    Foreground="{DynamicResource TextPrimaryBrush}"
    FontFamily="Segoe UI"
    FontSize="14"
    dft:ThemedTitleBar.IsEnabled="True">

    <Window.Resources>
        <CollectionViewSource x:Key="ThemesView" Source="{Binding Themes}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Family"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header (spans both columns) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ThemeForge Studio"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Galerie de composants WPF par thème"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Thème :"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="ThemeComboBox"
                              Width="220"
                              ItemsSource="{Binding Source={StaticResource ThemesView}}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              AutomationProperties.Name="Theme picker"
                              AutomationProperties.HelpText="Select a theme variant">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Margin="8,8,8,4"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ComboBox.GroupStyle>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                     DisplayMemberPath="Name"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Padding="8"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      Background="{DynamicResource SurfaceBrush}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentControl Content="{Binding SelectedSection.View}"
                            Margin="24"/>
        </ScrollViewer>
    </Grid>
</Window>
