  Licensed under the Apache License, Version 2.0 (framework code + palette).

  Variant: Drakul  |  Family: Dark
  Tagline: Drakul — Vlad II of the Order of the Dragon (1408), AA-compliant
           sibling of the canonical Dracula MIT palette.

  Palette attribution: derived from the canonical Dracula Theme palette
  (Zeno Rocha, MIT) with the Comment slot lifted from #6272A4 to #B3BBD6 so
  that Comment/Background and Comment/CurrentLine both clear WCAG 2.1 AA
  (4.5:1). Every other slot is byte-identical to canonical Dracula. The name
  honors Vlad II Dracul (~1395-1447), prince of Wallachia and member of the
  Societas Draconistarum (Order of the Dragon), historical father of Vlad III
  Țepeș from which Stoker derived "Dracula". Public domain. See NOTICE for
  the canonical attribution record.

  This variant exists because the canonical Dracula Comment (#6272A4) ratios
  to 3.03 vs Background and 1.94 vs CurrentLine — a known historical
  accessibility shortcoming of the original 2013 design. We preserve the
  Dracula variant unchanged for canonical fidelity, and ship Drakul as the
  accessible sibling.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Shared/DesignTokens.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <sys:String x:Key="ThemeDisplayName">Drakul</sys:String>
    <sys:String x:Key="ThemeFamily">Dark</sys:String>

    <!-- Canonical Dracula slot colors (Comment lifted for WCAG AA) -->
    <Color x:Key="BackgroundColor">#FF282A36</Color>
    <Color x:Key="CurrentLineColor">#FF44475A</Color>
    <Color x:Key="SelectionColor">#FF44475A</Color>
    <Color x:Key="ForegroundColor">#FFF8F8F2</Color>
    <Color x:Key="CommentColor">#FFB3BBD6</Color>
    <Color x:Key="CyanColor">#FF8BE9FD</Color>
    <Color x:Key="GreenColor">#FF50FA7B</Color>
    <Color x:Key="OrangeColor">#FFFFB86C</Color>
    <Color x:Key="PinkColor">#FFFF79C6</Color>
    <Color x:Key="PurpleColor">#FFBD93F9</Color>
    <Color x:Key="RedColor">#FFFF5555</Color>
    <Color x:Key="YellowColor">#FFF1FA8C</Color>

    <!-- Semantic surface / text tokens -->
    <Color x:Key="SurfaceColor">#FF282A36</Color>
    <Color x:Key="SurfaceAltColor">#FF44475A</Color>
    <Color x:Key="AccentColor">#FFBD93F9</Color>
    <Color x:Key="AccentHoverColor">#FFD5BEFC</Color>
    <Color x:Key="AccentPressedColor">#FFA170E6</Color>
    <Color x:Key="TextPrimaryColor">#FFF8F8F2</Color>
    <Color x:Key="TextSecondaryColor">#FFB3BBD6</Color>
    <Color x:Key="BorderColor">#FF44475A</Color>
    <Color x:Key="SuccessColor">#FF50FA7B</Color>
    <Color x:Key="WarningColor">#FFFFB86C</Color>
    <Color x:Key="ErrorColor">#FFFF5555</Color>
    <Color x:Key="InfoColor">#FF8BE9FD</Color>

    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="CurrentLineBrush"     Color="{StaticResource CurrentLineColor}"/>
    <SolidColorBrush x:Key="SelectionBrush"       Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush"      Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="CommentBrush"         Color="{StaticResource CommentColor}"/>
    <SolidColorBrush x:Key="CyanBrush"            Color="{StaticResource CyanColor}"/>
    <SolidColorBrush x:Key="GreenBrush"           Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="OrangeBrush"          Color="{StaticResource OrangeColor}"/>
    <SolidColorBrush x:Key="PinkBrush"            Color="{StaticResource PinkColor}"/>
    <SolidColorBrush x:Key="PurpleBrush"          Color="{StaticResource PurpleColor}"/>
    <SolidColorBrush x:Key="RedBrush"             Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush"          Color="{StaticResource YellowColor}"/>

    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"     Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush"   Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush"            Color="{StaticResource InfoColor}"/>

</ResourceDictionary>
