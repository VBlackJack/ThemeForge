<UserControl
    x:Class="DraculaForge.Studio.Views.ContainersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <StackPanel>

        <TextBlock Text="Conteneurs" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="TabControl, GroupBox, Expander, Border."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"/>

        <TextBlock Text="TabControl" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TabControl Height="120" Margin="0,0,0,20">
            <TabItem Header="Onglet A">
                <TextBlock Text="Contenu de l'onglet A" Margin="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </TabItem>
            <TabItem Header="Onglet B">
                <TextBlock Text="Contenu de l'onglet B" Margin="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </TabItem>
            <TabItem Header="Onglet C" IsEnabled="False">
                <TextBlock Text="Désactivé" Margin="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </TabItem>
        </TabControl>

        <TextBlock Text="GroupBox" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <GroupBox Header="Options" Margin="0,0,0,20" Padding="8">
            <StackPanel>
                <CheckBox Content="Option 1" Margin="0,0,0,4"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox Content="Option 2" IsChecked="True"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
        </GroupBox>

        <TextBlock Text="Expander" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Expander Header="Détails techniques" Margin="0,0,0,8">
            <TextBlock Margin="8" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Text="Contenu déplié de l'expander. Permet de cacher des détails secondaires."/>
        </Expander>
        <Expander Header="Plus d'informations" IsExpanded="True" Margin="0,0,0,20">
            <TextBlock Margin="8" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Text="Expander déjà déplié à l'ouverture."/>
        </Expander>

        <TextBlock Text="Border (surface élevée)" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Border Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="16">
            <StackPanel>
                <TextBlock Text="Card-like container" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Utilise SurfaceAltBrush + BorderBrush. Préfigure ce que DraculaForge.Controls.Card fournira."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
