<UserControl
    x:Class="ThemeForge.Studio.Views.NumericUpDownDemoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dfc="clr-namespace:ThemeForge.Controls.Composites;assembly=ThemeForge.Controls"
    Background="Transparent">

    <StackPanel Margin="0,16,0,20">
        <TextBlock Text="NumericUpDown"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="States"
                   Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <Grid MaxWidth="520" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Default integer"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:NumericUpDown Grid.Row="0"
                               Grid.Column="1"
                               Width="140"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,8"
                               Value="12"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Bounded range"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:NumericUpDown Grid.Row="1"
                               Grid.Column="1"
                               Width="140"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,8"
                               Minimum="0"
                               Maximum="100"
                               Value="48"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Decimal step"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:NumericUpDown Grid.Row="2"
                               Grid.Column="1"
                               Width="140"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,8"
                               DecimalPlaces="2"
                               SmallChange="0.25"
                               Value="3.5"/>

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Read only"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:NumericUpDown Grid.Row="3"
                               Grid.Column="1"
                               Width="140"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,8"
                               IsReadOnly="True"
                               Value="7"/>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Disabled"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:NumericUpDown Grid.Row="4"
                               Grid.Column="1"
                               Width="140"
                               HorizontalAlignment="Left"
                               IsEnabled="False"
                               Value="24"/>
        </Grid>
    </StackPanel>
</UserControl>
