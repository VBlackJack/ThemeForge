<UserControl
    x:Class="ThemeForge.Studio.Views.FeedbackView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <StackPanel>

        <TextBlock Text="Retour utilisateur" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="ProgressBar, Tooltip, badges sémantiques, status."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"/>

        <TextBlock Text="ProgressBar (déterminé)" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <ProgressBar Width="300" Height="14" HorizontalAlignment="Left" Margin="0,0,0,16"
                     Minimum="0" Maximum="100" Value="65"/>

        <TextBlock Text="ProgressBar (indéterminé)" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <ProgressBar Width="300" Height="14" HorizontalAlignment="Left" Margin="0,0,0,20"
                     IsIndeterminate="True"/>

        <TextBlock Text="Badges sémantiques (Border + Brush)" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <WrapPanel Margin="0,0,0,20">
            <Border Background="{DynamicResource SuccessBrush}" CornerRadius="3" Padding="8,3" Margin="0,0,8,8">
                <TextBlock Text="Success" Foreground="#000"/>
            </Border>
            <Border Background="{DynamicResource WarningBrush}" CornerRadius="3" Padding="8,3" Margin="0,0,8,8">
                <TextBlock Text="Warning" Foreground="#000"/>
            </Border>
            <Border Background="{DynamicResource ErrorBrush}" CornerRadius="3" Padding="8,3" Margin="0,0,8,8">
                <TextBlock Text="Error" Foreground="#fff"/>
            </Border>
            <Border Background="{DynamicResource InfoBrush}" CornerRadius="3" Padding="8,3" Margin="0,0,8,8">
                <TextBlock Text="Info" Foreground="#000"/>
            </Border>
        </WrapPanel>

        <TextBlock Text="Tooltip" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Button Content="Hover me" Width="100" HorizontalAlignment="Left" Margin="0,0,0,20"
                Padding="14,6">
            <Button.ToolTip>
                <ToolTip Content="Exemple de tooltip natif WPF."/>
            </Button.ToolTip>
        </Button>

        <TextBlock Text="StatusBar" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <StatusBar>
            <StatusBarItem Content="Prêt"/>
            <Separator/>
            <StatusBarItem Content="15 thèmes chargés"/>
        </StatusBar>

    </StackPanel>
</UserControl>
