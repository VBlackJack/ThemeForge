#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"

if ! command -v pwsh >/dev/null 2>&1; then
  echo "ThemeForge pre-push hook requires PowerShell 7+ (pwsh)." >&2
  echo "Install pwsh or bypass once with: git push --no-verify" >&2
  exit 1
fi

run_check() {
  script_path="$repo_root/tools/$1"
  pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$script_path"
}

run_check ci-explicit-types.ps1
run_check ci-xaml-headers.ps1
