<UserControl
    x:Class="DraculaForge.Studio.Views.InputsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <StackPanel>

        <TextBlock Text="Champs de saisie" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="TextBox, PasswordBox, CheckBox, RadioButton, ComboBox, Slider."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"/>

        <TextBlock Text="TextBox" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <StackPanel Margin="0,0,0,20">
            <TextBox Width="300" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="6,4"
                     Text="Single-line input"/>
            <TextBox Width="300" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="6,4"
                     Text="Disabled" IsEnabled="False"/>
            <TextBox Width="300" Height="80" HorizontalAlignment="Left" Padding="6,4"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Text="Multi-line input&#x0a;Second line"/>
        </StackPanel>

        <TextBlock Text="PasswordBox" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <PasswordBox Width="300" HorizontalAlignment="Left" Margin="0,0,0,20"
                     Padding="6,4" Password="hunter2"/>

        <TextBlock Text="CheckBox" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <CheckBox Content="Activé" IsChecked="True" Margin="0,0,16,0"
                      Foreground="{DynamicResource TextPrimaryBrush}"/>
            <CheckBox Content="Désactivé" Margin="0,0,16,0"
                      Foreground="{DynamicResource TextPrimaryBrush}"/>
            <CheckBox Content="Indéterminé" IsThreeState="True" IsChecked="{x:Null}"
                      Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <TextBlock Text="RadioButton" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton Content="Option A" IsChecked="True" GroupName="demo" Margin="0,0,16,0"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            <RadioButton Content="Option B" GroupName="demo" Margin="0,0,16,0"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            <RadioButton Content="Option C" GroupName="demo"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <TextBlock Text="ComboBox" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <ComboBox Width="200" HorizontalAlignment="Left" Margin="0,0,0,20" SelectedIndex="0">
            <ComboBoxItem Content="Option 1"/>
            <ComboBoxItem Content="Option 2"/>
            <ComboBoxItem Content="Option 3"/>
        </ComboBox>

        <TextBlock Text="Slider" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <Slider Width="300" HorizontalAlignment="Left" Margin="0,0,0,20"
                Minimum="0" Maximum="100" Value="42"
                TickPlacement="BottomRight" TickFrequency="10"/>

    </StackPanel>
</UserControl>
