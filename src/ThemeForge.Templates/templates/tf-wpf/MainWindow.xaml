<Window x:Class="ThemeForge.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ThemeForge.WpfApp"
        Width="480" Height="320"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Demo ThemeForge"
                   FontSize="{DynamicResource FontSizeXl}"
                   Foreground="{DynamicResource AccentBrush}"/>

        <TextBlock Text="Theme" Margin="0,16,0,4"/>
        <ComboBox ItemsSource="{Binding AvailableThemes}"
                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"/>

        <CheckBox Content="Suivre Windows"
                  IsChecked="{Binding FollowWindows, Mode=TwoWay}"
                  Margin="0,12,0,0"/>

        <Button Content="Bouton theme"
                Margin="0,20,0,0"
                HorizontalAlignment="Left"/>
    </StackPanel>
</Window>
