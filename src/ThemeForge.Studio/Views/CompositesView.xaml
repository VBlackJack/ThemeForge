<UserControl
    x:Class="ThemeForge.Studio.Views.CompositesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dfc="clr-namespace:ThemeForge.Controls.Composites;assembly=ThemeForge.Controls"
    xmlns:views="clr-namespace:ThemeForge.Studio.Views"
    Background="Transparent">

    <UserControl.Resources>
        <!-- Quick vector glyphs for the IconButton demo. -->
        <Geometry x:Key="Geo.Save">M 0,0 L 14,0 L 18,4 L 18,18 L 0,18 Z M 3,3 L 3,8 L 13,8 L 13,3 Z M 5,11 L 13,11 L 13,15 L 5,15 Z</Geometry>
        <Geometry x:Key="Geo.Trash">M 5,2 L 11,2 L 12,4 L 15,4 L 15,5 L 14,16 L 2,16 L 1,5 L 1,4 L 4,4 Z</Geometry>
        <Geometry x:Key="Geo.Plus">M 7,1 L 9,1 L 9,7 L 15,7 L 15,9 L 9,9 L 9,15 L 7,15 L 7,9 L 1,9 L 1,7 L 7,7 Z</Geometry>
        <Geometry x:Key="Geo.Settings">M 8,1 L 10,1 L 10.5,3.5 L 12.5,4 L 14,2.5 L 15.5,4 L 14,5.5 L 14.5,7.5 L 17,8 L 17,10 L 14.5,10.5 L 14,12.5 L 15.5,14 L 14,15.5 L 12.5,14 L 10.5,14.5 L 10,17 L 8,17 L 7.5,14.5 L 5.5,14 L 4,15.5 L 2.5,14 L 4,12.5 L 3.5,10.5 L 1,10 L 1,8 L 3.5,7.5 L 4,5.5 L 2.5,4 L 4,2.5 L 5.5,4 L 7.5,3.5 Z M 9,6 A 3,3 0 1 0 9,12 A 3,3 0 1 0 9,6</Geometry>
    </UserControl.Resources>

    <StackPanel>

        <TextBlock Text="Composites custom" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Card et IconButton — composites livrés par ThemeForge.Controls qui n'existent pas dans WPF natif."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"
                   TextWrapping="Wrap"/>

        <views:SegmentedControlDemoView/>
        <views:NumericUpDownDemoView/>
        <views:BreadcrumbDemoView/>

        <!-- Card examples -->
        <TextBlock Text="Card" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <dfc:Card Grid.Column="0" Header="Settings" Footer="Apply">
                <StackPanel>
                    <TextBlock Text="Card avec Header + Body + Footer." TextWrapping="Wrap"/>
                    <TextBlock Text="Surface élevée, header en Accent, divider subtle, footer en TextSecondary."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </dfc:Card>

            <dfc:Card Grid.Column="2" Header="Header seul">
                <TextBlock Text="Card sans Footer — divider du bas masqué automatiquement."
                           TextWrapping="Wrap"/>
            </dfc:Card>
        </Grid>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <dfc:Card Grid.Column="0">
                <TextBlock Text="Card body seul — pas de Header, pas de Footer. Les deux dividers sont masqués."
                           TextWrapping="Wrap"/>
            </dfc:Card>

            <dfc:Card Grid.Column="2" Footer="© 2026">
                <TextBlock Text="Card Body + Footer (pas de Header)." TextWrapping="Wrap"/>
            </dfc:Card>
        </Grid>

        <!-- IconButton examples -->
        <TextBlock Text="IconButton" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="Icon + Label" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <WrapPanel Margin="0,0,0,12">
            <dfc:IconButton Icon="{StaticResource Geo.Save}"     Label="Save"     Margin="0,0,8,8"/>
            <dfc:IconButton Icon="{StaticResource Geo.Trash}"    Label="Delete"   Margin="0,0,8,8"/>
            <dfc:IconButton Icon="{StaticResource Geo.Plus}"     Label="Add"      Margin="0,0,8,8"/>
            <dfc:IconButton Icon="{StaticResource Geo.Settings}" Label="Settings" Margin="0,0,8,8"/>
        </WrapPanel>

        <TextBlock Text="Icon seul (square)" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <WrapPanel Margin="0,0,0,12">
            <dfc:IconButton Icon="{StaticResource Geo.Save}"     Margin="0,0,8,8"/>
            <dfc:IconButton Icon="{StaticResource Geo.Trash}"    Margin="0,0,8,8"/>
            <dfc:IconButton Icon="{StaticResource Geo.Plus}"     Margin="0,0,8,8"/>
            <dfc:IconButton Icon="{StaticResource Geo.Settings}" Margin="0,0,8,8"/>
        </WrapPanel>

        <TextBlock Text="Disabled" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <WrapPanel Margin="0,0,0,20">
            <dfc:IconButton Icon="{StaticResource Geo.Save}" Label="Disabled" IsEnabled="False" Margin="0,0,8,8"/>
        </WrapPanel>

        <!-- Badge examples -->
        <TextBlock Text="Badge" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="Severity variants" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <WrapPanel Margin="0,0,0,20">
            <dfc:Badge Content="Default" Severity="Default" Margin="4"/>
            <dfc:Badge Content="Success" Severity="Success" Margin="4"/>
            <dfc:Badge Content="Warning" Severity="Warning" Margin="4"/>
            <dfc:Badge Content="Error"   Severity="Error"   Margin="4"/>
            <dfc:Badge Content="Info"    Severity="Info"    Margin="4"/>
        </WrapPanel>

        <!-- Chip examples -->
        <TextBlock Text="Chip" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="Variants" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <WrapPanel Margin="0,0,0,20">
            <dfc:Chip Content="Plain"      Margin="4"/>
            <dfc:Chip Content="With icon"  Icon="{StaticResource Geo.Settings}" Margin="4"/>
            <dfc:Chip Content="Removable"  IsRemovable="True" Margin="4"/>
            <dfc:Chip Content="Selected"   IsSelected="True"  Margin="4"/>
            <dfc:Chip Content="Disabled"   IsEnabled="False"  Margin="4"/>
        </WrapPanel>

        <!-- ToggleSwitch examples -->
        <TextBlock Text="Toggle switches" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="States" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <StackPanel Orientation="Vertical">
            <dfc:ToggleSwitch Content="Off (default)"                       Margin="0,0,0,6"/>
            <dfc:ToggleSwitch Content="On"               IsChecked="True"   Margin="0,0,0,6"/>
            <dfc:ToggleSwitch                                                Margin="0,0,0,6"/>
            <dfc:ToggleSwitch Content="Disabled (on)"    IsChecked="True"   IsEnabled="False" Margin="0,0,0,6"/>
        </StackPanel>

        <!-- Avatar examples -->
        <TextBlock Text="Avatar" FontWeight="SemiBold" Margin="0,16,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="Initials, multiple sizes" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
            <dfc:Avatar Initials="JB" Size="32" Margin="0,0,12,0"/>
            <dfc:Avatar Initials="JB" Size="40" Margin="0,0,12,0"/>
            <dfc:Avatar Initials="JB" Size="56" Margin="0,0,12,0"/>
            <dfc:Avatar Initials="AB" Size="40" Margin="0,0,12,0"/>
            <dfc:Avatar Initials="?"  Size="40" Margin="0,0,12,0"/>
        </StackPanel>

        <!-- SearchBox examples -->
        <TextBlock Text="SearchBox" FontWeight="SemiBold" Margin="0,16,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="States" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <StackPanel Orientation="Vertical" Margin="0,0,0,20">
            <dfc:SearchBox PlaceholderText="Search composites..." Width="320" HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <dfc:SearchBox PlaceholderText="With pre-filled text" Text="dracula" Width="320" HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <dfc:SearchBox PlaceholderText="Not clearable" IsClearable="False" Width="320" HorizontalAlignment="Left" Margin="0,0,0,8"/>
        </StackPanel>

        <!-- Toast examples -->
        <TextBlock Text="Toast" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="Click to push (auto-dismiss after 3s)" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <WrapPanel Margin="0,0,0,8">
            <Button Content="Info"    Click="OnShowInfo"    Margin="0,0,8,8"/>
            <Button Content="Success" Click="OnShowSuccess" Margin="0,0,8,8"/>
            <Button Content="Warning" Click="OnShowWarning" Margin="0,0,8,8"/>
            <Button Content="Error"   Click="OnShowError"   Margin="0,0,8,8"/>
        </WrapPanel>

        <dfc:ToastHost x:Name="DemoToastHost" Margin="0,0,0,20"
                       Width="320" HorizontalAlignment="Left"/>

        <!-- Dialog example -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="12" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Dialog" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button Content="Open dialog" Width="160" HorizontalAlignment="Left"
                        Click="OpenDialog_Click"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
