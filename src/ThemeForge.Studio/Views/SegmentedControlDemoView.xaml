<UserControl
    x:Class="ThemeForge.Studio.Views.SegmentedControlDemoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dfc="clr-namespace:ThemeForge.Controls.Composites;assembly=ThemeForge.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Background="Transparent">

    <StackPanel Margin="0,16,0,20">
        <TextBlock Text="SegmentedControl"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Text="Variantes"
                   Margin="0,0,0,4"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <Grid MaxWidth="640" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Période"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:SegmentedControl Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  SelectedIndex="0">
                <sys:String>Jour</sys:String>
                <sys:String>Semaine</sys:String>
                <sys:String>Mois</sys:String>
            </dfc:SegmentedControl>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Vue"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:SegmentedControl Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  SelectedIndex="1">
                <sys:String>Liste</sys:String>
                <sys:String>Grille</sys:String>
            </dfc:SegmentedControl>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Désactivé"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:SegmentedControl Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  SelectedIndex="0">
                <sys:String>Actif</sys:String>
                <dfc:SegmentItem Content="Archivé" IsEnabled="False"/>
                <sys:String>À venir</sys:String>
            </dfc:SegmentedControl>

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Contenu riche"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <dfc:SegmentedControl Grid.Row="3"
                                  Grid.Column="1"
                                  SelectedIndex="0">
                <dfc:SegmentItem>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M 2,8 L 6,12 L 14,3"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=dfc:SegmentItem}}"
                              StrokeThickness="1.8"
                              Width="14"
                              Height="14"
                              Margin="0,0,6,0"
                              Stretch="Uniform"/>
                        <TextBlock Text="Validé"/>
                    </StackPanel>
                </dfc:SegmentItem>
                <sys:String>Brouillon</sys:String>
                <sys:String>Publié</sys:String>
            </dfc:SegmentedControl>
        </Grid>
    </StackPanel>
</UserControl>
