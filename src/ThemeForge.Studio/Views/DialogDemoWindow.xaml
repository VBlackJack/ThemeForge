<Window
  x:Class="ThemeForge.Studio.Views.DialogDemoWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:composites="clr-namespace:ThemeForge.Controls.Composites;assembly=ThemeForge.Controls"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
  ResizeMode="NoResize"
  WindowState="Maximized"
  ShowInTaskbar="False"
  WindowStartupLocation="CenterOwner"
  Title="ThemeForge Dialog Demo">

  <Grid Background="#99000000">
    <composites:Dialog x:Name="DemoDialog"
                       Width="420"
                       MaxWidth="560"
                       Header="Confirm action"
                       Severity="Warning"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
      <composites:Dialog.Content>
        <TextBlock Text="This will permanently delete the selected items. Continue?"
                   TextWrapping="Wrap"/>
      </composites:Dialog.Content>
      <composites:Dialog.Footer>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel"
                  Width="100"
                  Margin="0,0,8,0"
                  Click="CancelButton_Click"/>
          <Button Content="Delete"
                  Width="100"
                  IsDefault="True"
                  Click="DeleteButton_Click"/>
        </StackPanel>
      </composites:Dialog.Footer>
    </composites:Dialog>
  </Grid>
</Window>
