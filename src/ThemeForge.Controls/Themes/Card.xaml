  Default style and template for the Card composite. Header / Body / Footer
  layout, surface elevated via SurfaceAltBrush + Border.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:composites="clr-namespace:ThemeForge.Controls.Composites">

    <Style TargetType="{x:Type composites:Card}">
        <Setter Property="Background"    Value="{DynamicResource SurfaceAltBrush}"/>
        <Setter Property="Foreground"    Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"       Value="16"/>
        <Setter Property="FontFamily"    Value="Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type composites:Card}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ContentPresenter x:Name="HeaderRegion"
                                              Grid.Row="0"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="SemiBold"
                                              TextElement.FontSize="14"
                                              TextElement.Foreground="{DynamicResource AccentBrush}"/>

                            <Border x:Name="HeaderDivider"
                                    Grid.Row="0"
                                    Height="1"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource BorderBrush}"
                                    Opacity="0.5"/>

                            <ContentPresenter Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>

                            <Border x:Name="FooterDivider"
                                    Grid.Row="2"
                                    Height="1"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource BorderBrush}"
                                    Opacity="0.5"/>

                            <ContentPresenter x:Name="FooterRegion"
                                              Grid.Row="2"
                                              Content="{TemplateBinding Footer}"
                                              ContentTemplate="{TemplateBinding FooterTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter Property="Visibility" TargetName="HeaderRegion"  Value="Collapsed"/>
                            <Setter Property="Visibility" TargetName="HeaderDivider" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Footer" Value="{x:Null}">
                            <Setter Property="Visibility" TargetName="FooterRegion"  Value="Collapsed"/>
                            <Setter Property="Visibility" TargetName="FooterDivider" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
