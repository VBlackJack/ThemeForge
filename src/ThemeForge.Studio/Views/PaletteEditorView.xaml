<UserControl
    x:Class="ThemeForge.Studio.Views.PaletteEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="SlotItemTemplate">
            <Grid Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="32" Height="32"
                        CornerRadius="3"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding Color}"/>
                    </Border.Background>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <TextBox Grid.Column="2"
                         Text="{Binding Hex, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinHeight="28"
                         Padding="6,3"
                         FontFamily="Consolas"
                         AutomationProperties.Name="{Binding Name, StringFormat='{}{0} hex value'}"
                         AutomationProperties.HelpText="Edit the hex color for this palette slot"/>

                <Button Grid.Column="3"
                        Content="Reset"
                        Margin="6,0,0,0"
                        Padding="10,3"
                        MinHeight="28"
                        Command="{Binding ResetCommand}"
                        AutomationProperties.Name="{Binding Name, StringFormat='{}Reset {0}'}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel>

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Éditeur de palette" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Modifie un slot en direct — les contrôles de la galerie se mettent à jour automatiquement. Changer de thème écrase les modifs."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Reset all"
                    VerticalAlignment="Top"
                    Margin="12,0,0,0"
                    Command="{Binding ResetAllCommand}"/>
        </Grid>

        <TextBlock Text="Slots canoniques" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8"/>
        <ItemsControl ItemsSource="{Binding CanonicalSlots}"
                      ItemTemplate="{StaticResource SlotItemTemplate}"
                      Margin="0,0,0,20"/>

        <TextBlock Text="Tokens sémantiques" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8"/>
        <ItemsControl ItemsSource="{Binding SemanticSlots}"
                      ItemTemplate="{StaticResource SlotItemTemplate}"/>

    </StackPanel>
</UserControl>
