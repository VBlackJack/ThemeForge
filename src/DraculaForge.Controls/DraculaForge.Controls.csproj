<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>DraculaForge.Controls</RootNamespace>
    <AssemblyName>DraculaForge.Controls</AssemblyName>
    <PackageId>DraculaForge.Controls</PackageId>
    <Description>Themed WPF control styles and composite controls (Card, IconButton, ToggleSwitch...) wired to the DraculaForge.Theme engine.</Description>
    <PackageTags>wpf;controls;dracula;theme;styles</PackageTags>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DraculaForge.Theme\DraculaForge.Theme.csproj" />
  </ItemGroup>

</Project>
