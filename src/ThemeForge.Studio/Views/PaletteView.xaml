<UserControl
    x:Class="ThemeForge.Studio.Views.PaletteView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <StackPanel>

        <TextBlock Text="Slots Dracula canoniques"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Les 12 slots de base de la palette Dracula."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"/>

        <UniformGrid Columns="4" Rows="3" Margin="0,0,0,24">
            <Border Margin="4" Background="{DynamicResource BackgroundBrush}"  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Background"  Margin="8" Foreground="{DynamicResource ForegroundBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource CurrentLineBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="CurrentLine" Margin="8" Foreground="{DynamicResource ForegroundBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource SelectionBrush}"   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Selection"   Margin="8" Foreground="{DynamicResource ForegroundBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource CommentBrush}"     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Comment"     Margin="8" Foreground="{DynamicResource BackgroundBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource CyanBrush}"        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Cyan"        Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource GreenBrush}"       BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Green"       Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource OrangeBrush}"      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Orange"      Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource PinkBrush}"        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Pink"        Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource PurpleBrush}"      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Purple"      Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource RedBrush}"         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Red"         Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource YellowBrush}"      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Yellow"      Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource ForegroundBrush}"  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Foreground"  Margin="8" Foreground="{DynamicResource BackgroundBrush}"/>
            </Border>
        </UniformGrid>

        <TextBlock Text="Tokens sémantiques"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Dérivés de la palette, utilisés par les composants."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"/>

        <UniformGrid Columns="4" Rows="3">
            <!-- Row 1: structure -->
            <Border Margin="4" Background="{DynamicResource SurfaceBrush}"        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Surface"        Margin="8" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource SurfaceAltBrush}"     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="SurfaceAlt"     Margin="8" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource BorderBrush}"         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Border"         Margin="8" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource TextPrimaryBrush}"    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="TextPrimary"    Margin="8" Foreground="{DynamicResource BackgroundBrush}"/>
            </Border>

            <!-- Row 2: accent triad + secondary text -->
            <Border Margin="4" Background="{DynamicResource AccentBrush}"         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Accent"         Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource AccentHoverBrush}"    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="AccentHover"    Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource AccentPressedBrush}"  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="AccentPressed"  Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource TextSecondaryBrush}"  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="TextSecondary"  Margin="8" Foreground="{DynamicResource BackgroundBrush}"/>
            </Border>

            <!-- Row 3: feedback -->
            <Border Margin="4" Background="{DynamicResource SuccessBrush}"        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Success"        Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource WarningBrush}"        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Warning"        Margin="8" Foreground="#000"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource ErrorBrush}"          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Error"          Margin="8" Foreground="#fff"/>
            </Border>
            <Border Margin="4" Background="{DynamicResource InfoBrush}"           BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="60">
                <TextBlock Text="Info"           Margin="8" Foreground="#000"/>
            </Border>
        </UniformGrid>

    </StackPanel>
</UserControl>
